import java.util.Scanner;

public class Main {
    public static int userLogic(int n, int[] arr) {
        long MOD = 1_000_000_007;
        
        // Step 1: Calculate the sum of all original indices.
        // Sum of 0 to n-1 = (n - 1) * n / 2
        long sumOriginalIndices = ((long)(n - 1) * n / 2) % MOD;
        
        // Find the maximum value in the array to size our frequency tracker
        int maxVal = 0;
        for (int num : arr) {
            if (num > maxVal) {
                maxVal = num;
            }
        }
        
        // Step 2: Build a frequency array
        int[] freq = new int[maxVal + 1];
        for (int num : arr) {
            freq[num]++;
        }
        
        // Step 3: Compute prefix sums to find the last occurrence index boundary for each value
        // lastOccurrenceIndex[v] = prefixSum[v] - 1
        int[] lastIndexMap = new int[maxVal + 1];
        int currentPrefixSum = 0;
        for (int i = 0; i <= maxVal; i++) {
            if (freq[i] > 0) {
                currentPrefixSum += freq[i];
                lastIndexMap[i] = currentPrefixSum - 1;
            }
        }
        
        // Step 4: Sum up the last occurrence index for every element present in the array
        long sumSortedIndices = 0;
        for (int num : arr) {
            sumSortedIndices = (sumSortedIndices + lastIndexMap[num]) % MOD;
        }
        
        // Total measurement is the combined sum of both parts
        long totalMeasurement = (sumOriginalIndices + sumSortedIndices) % MOD;
        
        return (int) totalMeasurement;
    }

    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        if (scanner.hasNextInt()) {
            int n = scanner.nextInt();
            int[] arr = new int[n];
            for (int i = 0; i < n; i++) {
                arr[i] = scanner.nextInt();
            }
            int measurement = userLogic(n, arr);
            System.out.println(measurement);
        }
        scanner.close();
    }
}
