import java.util.*;
/*
 * class Graph {
	int V; // No. of vertices
	ArrayList<Integer> adj[]; // Pointer to an array containing adjacency lists
 */
public class solution {
	static boolean dfs(int node, int parent, boolean[] visited, Graph g)
	{
		visited[node] = true;
		for(int neighbor : g.adj[node])
		{
			if(!visited[neighbor])
			{
				if(dfs(neighbor, node, visited, g))
				{
					return true;
				}
			}
			else if(neighbor != parent)
			{
				return true;
			}
		}
		return false;
	}
	public static boolean isCyclic(Graph g) {
	 /*Your class should be named solution. 
		*Don't write main().
		*Don't take input, it is passed as function argument.
		*Don't print output.
		*Taking input and printing output is handled automatically.
	*/ 
		boolean[] visited = new boolean[g.V];
		for(int i = 0;i <g.V;i++)
		{
			if(!visited[i])
			{
				if(dfs(i, -1, visited, g))
				{
					return true;
				}
			}
		}
		return false;
	}
}
