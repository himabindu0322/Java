import java.util.*;

public class Main {
    public static int find_winner(int[] arr) {
        // Frequency map to store the occurrence count of each number
        HashMap<Integer, Integer> freqMap = new HashMap<>();

        // First pass: Count frequencies of all elements
        for (int num : arr) {
            freqMap.put(num, freqMap.getOrDefault(num, 0) + 1);
        }

        // Second pass: Find the first element with a frequency of 1
        for (int num : arr) {
            if (freqMap.get(num) == 1) {
                return num; // Found the first unique number
            }
        }

        // If no unique number is found, return 0
        return 0;
    }

    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        if (scanner.hasNextInt()) {
            int n = scanner.nextInt();
            int[] arr = new int[n];
            for (int i = 0; i < n; i++) {
                arr[i] = scanner.nextInt();
            }
            int result = find_winner(arr);
            System.out.println(result);
        }
        scanner.close();
    }
}
