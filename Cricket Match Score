import java.util.*;

public class Main {
    // Greedy approach to find if the target index (N - 1) can be reached
    public static boolean userLogic(int n, int[] runs) {
        int maxReachable = 0;
        
        for (int i = 0; i < n; i++) {
            // If the current index is greater than the maximum index we can reach,
            // then it's impossible to progress further.
            if (i > maxReachable) {
                return false;
            }
            
            // Update the furthest index reachable
            maxReachable = Math.max(maxReachable, i + runs[i]);
            
            // If we can reach or exceed the final target score (n - 1), return true
            if (maxReachable >= n - 1) {
                return true;
            }
        }
        
        return maxReachable >= n - 1;
    }

    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        if (scanner.hasNextInt()) {
            int n = scanner.nextInt();
            int[] runs = new int[n];
            for (int i = 0; i < n; ++i) {
                runs[i] = scanner.nextInt();
            }

            // Call user logic function and print the output
            boolean result = userLogic(n, runs);
            System.out.println(result ? "true" : "false");
        }
        scanner.close();
    }
}
