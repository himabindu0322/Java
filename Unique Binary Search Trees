import java.util.Scanner;

public class Main {
    // Function to calculate the number of unique BSTs (using Catalan number formula)
    public static int numTrees(int n) {
        // Base cases
        if (n == 0 || n == 1) {
            return 1;
        }

        // dp[i] will store the i-th Catalan number
        int[] dp = new int[n + 1];
        
        // Base initializations
        dp[0] = 1;
        dp[1] = 1;

        // Fill the DP table using the Catalan number recurrence relation
        for (int i = 2; i <= n; i++) {
            for (int j = 0; j < i; j++) {
                dp[i] += dp[j] * dp[i - 1 - j];
            }
        }

        return dp[n];
    }

    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        if (scanner.hasNextInt()) {
            int number_of_nodes = scanner.nextInt();
            // Output the result: the total number of unique BSTs
            System.out.println(numTrees(number_of_nodes));
        }
        scanner.close();
    }
}
