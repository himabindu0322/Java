import java.util.Scanner;

public class Main {
    public static int calculateSum(int[] nums) {
        int n = nums.length;
        long arraySum = 0; // Use long to prevent any potential overflow before final cast if required
        
        // Step 1: Calculate the sum of all elements in the array
        for (int num : nums) {
            arraySum += num;
        }
        
        // Step 2: Cycle sort / placement logic to find the smallest missing positive integer
        // We want to place each number x (where 1 <= x <= n) at index x - 1
        for (int i = 0; i < n; i++) {
            while (nums[i] > 0 && nums[i] <= n && nums[nums[i] - 1] != nums[i]) {
                // Swap nums[i] with the element at its target index (nums[i] - 1)
                int temp = nums[nums[i] - 1];
                nums[nums[i] - 1] = nums[i];
                nums[i] = temp;
            }
        }
        
        // Find the first index where the correct number is missing
        int missingPositive = n + 1; 
        for (int i = 0; i < n; i++) {
            if (nums[i] != i + 1) {
                missingPositive = i + 1;
                break;
            }
        }
        
        // Step 3: Get the ASCII value of the first digit of the missing positive integer
        String missingStr = String.valueOf(missingPositive);
        int asciiValue = (int) missingStr.charAt(0);
        
        // Return the final computed sum
        return (int) (arraySum + asciiValue);
    }

    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        if (scanner.hasNextInt()) {
            int n = scanner.nextInt();
            int[] nums = new int[n];
            for (int i = 0; i < n; i++) {
                nums[i] = scanner.nextInt();
            }
            int result = calculateSum(nums);
            System.out.println(result);
        }
        scanner.close();
    }
}
