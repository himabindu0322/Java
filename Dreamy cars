import java.util.Scanner;

public class Main {
    public static int calculateFScore(int[] features, int N) {
        int totalXOR = 0;
        
        for (int i = 0; i < N; i++) {
            // Count of subarrays that include features[i]
            // Using long to prevent integer overflow during multiplication
            long count = (long) (i + 1) * (N - i);
            
            // If the element appears an odd number of times, include it in the result
            if (count % 2 != 0) {
                totalXOR ^= features[i];
            }
        }
        
        return totalXOR;
    }

    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        if (sc.hasNextInt()) {
            int N = sc.nextInt();
            int[] features = new int[N];
            for (int i = 0; i < N; i++) {
                features[i] = sc.nextInt();
            }
            int result = calculateFScore(features, N);
            System.out.println(result);
        }
        sc.close();
    }
}
