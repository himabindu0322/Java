import java.util.Scanner;

public class Main {
    public static void modifyString(int n, String s) {
        int primeSum = 0;
        int primeCount = 0;

        // Step 1: Find all single-digit prime numbers in the string
        for (int i = 0; i < n; i++) {
            char ch = s.charAt(i);
            if (Character.isDigit(ch)) {
                int digit = ch - '0';
                // Single-digit primes are 2, 3, 5, 7
                if (digit == 2 || digit == 3 || digit == 5 || digit == 7) {
                    primeSum += digit;
                    primeCount++;
                }
            }
        }

        // Determine the unique number for modulo arithmetic
        int uniqueNumber = -1;
        if (primeCount > 0) {
            uniqueNumber = primeSum / primeCount; // Integer division handles the floor automatically
        }

        // Step 2 & 3: Construct the modified string
        StringBuilder result = new StringBuilder();
        for (int i = 0; i < n; i++) {
            char ch = s.charAt(i);
            
            if (Character.isDigit(ch)) {
                int digit = ch - '0';
                int index;
                
                // If prime numbers existed, use (digit % uniqueNumber)
                if (uniqueNumber != -1) {
                    index = digit % uniqueNumber;
                } else {
                    // If no primes existed, use the digit value directly
                    index = digit;
                }
                
                // Map index to 'a' through 'z'
                char replacedChar = (char) ('a' + index);
                result.append(replacedChar);
            } else {
                // If it's already an alphabet character, keep it unchanged
                result.append(ch);
            }
        }

        // Output the final modified string
        System.out.println(result.toString());
    }

    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        if (scanner.hasNextInt()) {
            int n = scanner.nextInt();
            if (scanner.hasNext()) {
                String s = scanner.next();
                modifyString(n, s);
            }
        }
        scanner.close();
    }
}
