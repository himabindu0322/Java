import java.util.Scanner;

class Main {
    public static int find_largest_pack(int N) {
        // Integer.highestOneBit(N) returns an int value with at most a single one-bit, 
        // in the position of the highest-order ("leftmost") one-bit in the specified int value.
        return Integer.highestOneBit(N);
    }

    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        if (scanner.hasNextInt()) {
            int N = scanner.nextInt();
            int result = find_largest_pack(N);
            System.out.println(result);
        }
        scanner.close();
    }
}
