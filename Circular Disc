import java.util.Scanner;
import java.util.Arrays;

public class Main {
    public static int minTimeToType(String word) {
        // Convert the string to a character array and sort it alphabetically
        char[] chars = word.toCharArray();
        Arrays.sort(chars);

        int totalSeconds = 0;
        char currentPos = 'a'; // Pointer starts at 'a'

        for (int i = 0; i < chars.length; i++) {
            char targetChar = chars[i];

            // Calculate absolute structural distance between current character and target character
            int absoluteDiff = Math.abs(targetChar - currentPos);

            // Minimum steps between clockwise and counter-clockwise movement
            int movementSteps = Math.min(absoluteDiff, 26 - absoluteDiff);

            // Total time for this character = steps to move + 1 second to print/type
            totalSeconds += movementSteps + 1;

            // Move the pointer position to the typed character
            currentPos = targetChar;
        }

        return totalSeconds;
    }

    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        if (scanner.hasNextLine()) {
            String word = scanner.nextLine();
            int result = minTimeToType(word);
            System.out.println(result);
        }
        scanner.close();
    }
}
