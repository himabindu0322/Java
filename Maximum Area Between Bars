import java.util.List;

class Solution {
    public int maxArea(List<Integer> height) {
        int left = 0;
        int right = height.size() - 1;
        int maxArea = 0;
        
        while (left < right) {
            // Number of bars strictly between left and right
            int width = right - left - 1;
            
            // Area is only possible if there is at least 1 bar between them
            if (width > 0) {
                int currentArea = Math.min(height.get(left), height.get(right)) * width;
                maxArea = Math.max(maxArea, currentArea);
            }
            
            // Move the pointer corresponding to the smaller height inwards
            if (height.get(left) < height.get(right)) {
                left++;
            } else {
                right--;
            }
        }
        
        return maxArea;
    }
}
