import java.util.*;
import java.io.*;

public class Solution {
	public static String zigzagConversion(String s, int row) {

		if (row == 1 || row >= s.length()) {
			return s;
		}

		StringBuilder[] rows = new StringBuilder[row];

		for (int i = 0; i < row; i++) {
			rows[i] = new StringBuilder();
		}

		int currRow = 0;
		boolean goingDown = true;

		for (char ch : s.toCharArray()) {
			rows[currRow].append(ch);

			if (currRow == 0) {
				goingDown = true;
			} else if (currRow == row - 1) {
				goingDown = false;
			}

			if (goingDown) {
				currRow++;
			} else {
				currRow--;
			}
		}

		StringBuilder ans = new StringBuilder();

		for (int i = 0; i < row; i++) {
			ans.append(rows[i]);
		}

		return ans.toString();
	}
}
