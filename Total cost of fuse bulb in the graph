import java.util.*;

public class Main {
    public static int calculateTotalCost(int k, int n, int m, List<int[]> graph) {
        // Edge case handling: Division by zero prevention
        if (m <= 0) {
            return 0;
        }

        // Since the graph is guaranteed to be a single connected component, 
        // all nodes from 0 to N are fully reachable.
        // We calculate the number of bulbs between 1 and N that are divisible by M.
        int nonFunctionalCount = n / m;

        // Total cost = count of non-functional bulbs * cost per bulb
        return nonFunctionalCount * k;
    }

    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        if (!scanner.hasNextInt()) return;
        
        int k = scanner.nextInt();  // Price of the bulb
        int n = scanner.nextInt();  // Total number of bulbs
        int m = scanner.nextInt();  // Number of bulbs divisible by m
        int lenGraph = scanner.nextInt();  // Length of the 2D array
        
        // Fast skip/read of the graph entries to ensure optimal execution time
        List<int[]> graph = new ArrayList<>();
        for (int i = 0; i < lenGraph; i++) {
            if (scanner.hasNextInt()) {
                int u = scanner.nextInt();
                int v = scanner.nextInt();
                graph.add(new int[]{u, v});
            }
        }
        
        // Call user logic function and print the output
        int totalCost = calculateTotalCost(k, n, m, graph);
        System.out.println(totalCost);
        
        scanner.close();
    }
}
