import java.util.*;
import java.io.*; 
import java.util.ArrayList;

public class Solution {

    public static int maxOne(ArrayList<ArrayList<Integer>> arr) {
        if (arr == null || arr.isEmpty() || arr.get(0).isEmpty()) {
            return -1;
        }

        int n = arr.size();       // Number of rows
        int m = arr.get(0).size(); // Number of columns
        
        int maxOneRowIdx = 0;
        int r = 0;
        int c = m - 1; // Start from top-right corner

        while (r < n && c >= 0) {
            // If the element is 1, move left to find more 1s in this row
            if (arr.get(r).get(c) == 1) {
                maxOneRowIdx = r;
                c--;
            } 
            // If the element is 0, move down to check the next row
            else {
                r++;
            }
        }

        return maxOneRowIdx;
    }
}
