import java.util.*;
import java.io.*; 

public class Solution {
    public static String encode(String secretInformation) {
        if (secretInformation == null) {
            return "";
        }
        
        StringBuilder encoded = new StringBuilder();
        int n = secretInformation.length();
        
        for (int i = 0; i < n; i++) {
            char originalChar = secretInformation.charAt(i);
            // Shift forward by 3 (like a standard Caesar Cipher) 
            // without wrapping to 0, maintaining character sequence integrity
            char encodedChar = (char) (originalChar + 3);
            encoded.append(encodedChar);
        }
        
        return encoded.toString();
    }

    public static String decode(String encodedInformation) {
        if (encodedInformation == null) {
            return "";
        }
        
        StringBuilder decoded = new StringBuilder();
        int n = encodedInformation.length();
        
        for (int i = 0; i < n; i++) {
            char encodedChar = encodedInformation.charAt(i);
            // Shift backward by 3 to recover the exact original character
            char decodedChar = (char) (encodedChar - 3);
            decoded.append(decodedChar);
        }
        
        return decoded.toString();
    }
}
