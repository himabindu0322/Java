import java.util.*;

public class Main {
    public static int countTriplets(int n, int[] arr) {
        // The maximum value an element can take is < 2^16 (65536)
        int MAX_VAL = 1 << 16;
        int[] countPairs = new int[MAX_VAL];
        
        // Step 1: Count the frequency of all pairwise AND values
        for (int i = 0; i < n; i++) {
            for (int j = 0; j < n; j++) {
                int andPair = arr[i] & arr[j];
                countPairs[andPair]++;
            }
        }
        
        int totalTriplets = 0;
        
        // Step 2: Combine with the 3rd element 'arr[k]'
        for (int k = 0; k < n; k++) {
            for (int pairVal = 0; pairVal < MAX_VAL; pairVal++) {
                // If this specific pairwise AND value exists and results in 0 with arr[k]
                if (countPairs[pairVal] > 0 && (pairVal & arr[k]) == 0) {
                    totalTriplets += countPairs[pairVal];
                }
            }
        }
        
        return totalTriplets;
    }
    
    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        if (scanner.hasNextInt()) {
            int n = scanner.nextInt();
            int[] arr = new int[n];
            for (int i = 0; i < n; i++) {
                arr[i] = scanner.nextInt();
            }
            
            int result = countTriplets(n, arr);
            System.out.println(result);
        }
        scanner.close();
    }
}
