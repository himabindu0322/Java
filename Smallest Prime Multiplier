import java.util.*;

public class Main {
    // Helper method to calculate the Greatest Common Divisor (GCD) using the Euclidean algorithm
    private static long gcd(long a, long b) {
        while (b != 0) {
            long temp = b;
            b = a % b;
            a = temp;
        }
        return a;
    }

    public static long computeX(long p, long n) {
        // LCM(p, n) = (p * n) / GCD(p, n)
        // Divide before multiplying to completely avoid any chance of a temporary overflow
        return (p / gcd(p, n)) * n;
    }

    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        if (!scanner.hasNextLong()) return;
        
        long p = scanner.nextLong();  // First input is the long long integer p
        long n = scanner.nextLong();  // Second input is the long long integer n
        
        // Call user logic function and print the output
        long result = computeX(p, n);
        System.out.println(result);
        
        scanner.close();
    }
}
