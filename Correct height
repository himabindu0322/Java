import java.util.*;

public class Main {
    // Function to calculate the number of mismatched indices
    public static int heightChecker(int[] heights) {
        // Clone the original heights array to keep track of the initial order
        int[] expected = heights.clone();
        
        // Sort the cloned array to get the expected non-decreasing order
        Arrays.sort(expected);
        
        int mismatchCount = 0;
        
        // Compare the current height array with the expected height array
        for (int i = 0; i < heights.length; i++) {
            if (heights[i] != expected[i]) {
                mismatchCount++;
            }
        }
        
        return mismatchCount;
    }

    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        if (sc.hasNextInt()) {
            int n = sc.nextInt();
            int[] arr = new int[n];
            for (int i = 0; i < n; i++) {
                arr[i] = sc.nextInt();
            }
            int result = heightChecker(arr);
            System.out.println(result);
        }
        sc.close();
    }
}
