import java.util.Scanner;

public class Main {
    public static int user_logic(int n) {
        // If N is already even, it will take N / 2 operations of subtracting 2
        if (n % 2 == 0) {
            return n / 2;
        }

        // If N is odd, find its smallest prime factor
        int smallestPrimeFactor = n;
        
        // We only need to check odd numbers up to sqrt(n)
        for (int i = 3; (long)i * i <= n; i += 2) {
            if (n % i == 0) {
                smallestPrimeFactor = i;
                break;
            }
        }

        // 1 operation to subtract the odd prime factor, 
        // which leaves an even number that takes (n - smallestPrimeFactor) / 2 steps.
        return 1 + (n - smallestPrimeFactor) / 2;
    }

    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        int n = scanner.nextInt();

        // Call user logic function and print the output
        int result = user_logic(n);
        System.out.println(result);
        
        scanner.close();
    }
}
